{
  "name": "@safeloop/mmaw-adapter",
  "version": "0.0.0",
  "private": true,
  "description": "Pre-sign runtime safety layer for MetaMask Agent Wallet.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./metamask": {
      "types": "./dist/metamask.d.ts",
      "default": "./dist/metamask.js"
    },
    "./hip3": {
      "types": "./dist/hip3.d.ts",
      "default": "./dist/hip3.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
